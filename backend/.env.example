# Environment variables for the application
# Copy this file to .env and replace the placeholder values with your actual configuration.

# Database connection string
DATABASE_URL=postgresql://your_db_user:your_db_password@your_db_host:5432/your_db_name

# Port for the backend server
PORT=3000

# JWT secret key for token generation and verification
JWT_SECRET=your_very_secret_jwt_key_please_change_me

# AWS S3 Configuration (if applicable)
# These are only needed if you are using S3 for file storage.
# AWS_ACCESS_KEY_ID=your_aws_access_key_id
# AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# AWS_REGION=your_aws_region
# AWS_S3_BUCKET_NAME=your_s3_bucket_name # Renamed from S3_BUCKET_NAME to match s3Service.js

# Site Logo URL (fetched from S3 or a default placeholder)
# This should be the full S3 URL after uploading the logo, e.g., https://your_s3_bucket_name.s3.your_aws_region.amazonaws.com/logos/site_logo.svg
SITE_LOGO_URL=https://your_s3_bucket_name.s3.your_aws_region.amazonaws.com/logos/site_logo.svg

# Other potential variables
# NODE_ENV=development
