<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Verify Your Email for <%= siteName %></title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      padding: 0;
      background-color: #FFF5F8; /* Light Pastel */
      color: #333333;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }
    .container {
      width: 100%;
      max-width: 600px;
      margin: 20px auto;
      background-color: #FFFFFF;
      border-radius: 8px;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
      overflow: hidden;
    }
    .header {
      background-color: #FC7099; /* Peach Pink */
      color: #FFFFFF;
      padding: 20px;
      text-align: center;
    }
    .header h1 {
      margin: 0;
      font-size: 24px;
    }
    .content {
      padding: 25px 30px;
      line-height: 1.6;
    }
    .content p {
      margin: 0 0 15px 0;
    }
    .verification-code-container { /* Renamed from code-container for clarity */
      text-align: center;
      margin: 20px 0;
    }
    .verification-code {
      display: inline-block;
      background-color: #F9D849; /* Lemon Yellow for code background */
      color: #333333; /* Darker text for readability on yellow */
      padding: 10px 20px;
      font-size: 28px;
      font-weight: bold;
      letter-spacing: 3px;
      border-radius: 5px;
      border: 1px solid #F6A03C; /* Orange Gold border */
    }
    .expiry-info {
      font-size: 0.9em;
      color: #555555;
      text-align: center; /* Center expiry info */
    }
    .footer {
      text-align: center;
      padding: 20px;
      font-size: 0.85em;
      color: #777777;
      background-color: #FFF5F8; /* Light Pastel */
    }
    .footer p {
      margin: 5px 0;
    }
    a {
      color: #FC7099; /* Peach Pink for links */
      text-decoration: underline;
    }
    a:hover {
      text-decoration: none;
    }
    .site-name {
        font-weight: bold;
    }
    /* Added button styles for potential future use in this template if a direct link/button is added */
    .button-link {
      display: inline-block;
      background-color: #FC7099; /* Peach Pink */
      color: #FFFFFF !important;
      padding: 12px 25px;
      text-decoration: none;
      border-radius: 5px;
      font-weight: bold;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>Verify Your Email Address</h1>
    </div>
    <div class="content">
      <p>Hi <%= userName %>,</p>
      <p>Thanks for registering at <span class="site-name"><%= siteName %></span>! To complete your registration and activate your account, please use the verification code below.</p>

      <div class="verification-code-container">
        <p>Your verification code is:</p>
        <div class="verification-code"><%= verificationCode %></div>
      </div>

      <p class="expiry-info">This code will expire in <%= expiresInMinutes %> minutes.</p>
      <p>If you did not request this email, please ignore it.</p>
      <p>Best regards,<br>The <span class="site-name"><%= siteName %></span> Team</p>
    </div>
    <div class="footer">
      <p>&copy; <%= new Date().getFullYear() %> <span class="site-name"><%= siteName %></span>. All rights reserved.</p>
      <% if (typeof companyAddress !== 'undefined' && companyAddress) { %>
        <p><%= companyAddress %></p>
      <% } %>
    </div>
  </div>
</body>
</html>
