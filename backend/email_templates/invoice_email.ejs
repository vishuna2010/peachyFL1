<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Your Invoice from <%= siteName %></title>
  <style>
    body {
      font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif;
      margin: 0;
      padding: 0;
      background-color: #f4f4f4;
      color: #333333;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }
    .email-container {
      max-width: 600px;
      margin: 20px auto;
      background-color: #ffffff;
      border: 1px solid #dddddd;
      border-radius: 8px;
      overflow: hidden;
    }
    .header {
      background-color: #007bff; /* Placeholder: Info/Primary Blue */
      color: #ffffff;
      padding: 20px;
      text-align: center;
    }
    .header h1 {
      margin: 0;
      font-size: 22px;
    }
    .content {
      padding: 25px 30px;
      text-align: left;
      line-height: 1.6;
    }
    .content p {
      margin: 0 0 15px 0;
    }
    .footer {
      text-align: center;
      padding: 20px;
      font-size: 0.85em;
      color: #6c757d; /* Placeholder Secondary Color */
      background-color: #f8f9fa;
      border-top: 1px solid #e9ecef;
    }
    .footer p {
      margin: 5px 0;
    }
    .site-name {
        font-weight: bold;
    }
     a {
      color: #007bff; /* Placeholder Primary/Link Color */
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <div class="email-container">
    <div class="header">
      <h1>Your Invoice from <span class="site-name"><%= siteName %></span></h1>
    </div>
    <div class="content">
      <p>Dear <%= userName %>,</p>
      <p>Thank you for your recent order! Please find your invoice (Order #<%= orderId %>) attached to this email as a PDF document.</p>

      <% if (typeof orderTotal !== 'undefined' && orderTotal && typeof currencySymbol !== 'undefined' && currencySymbol) { %>
        <p><strong>Order Total:</strong> <%= currencySymbol %><%= orderTotal %></p>
      <% } %>

      <% if (typeof viewOrderLink !== 'undefined' && viewOrderLink) { %>
        <p>You can also view your order details online by visiting: <a href="<%= viewOrderLink %>">View Your Order</a></p>
      <% } %>

      <p>If you have any questions regarding your invoice or order, please feel free to <a href="mailto:<%= supportEmail %>">contact our support team</a>.</p>
      <p>We appreciate your business!</p>
      <p>Sincerely,<br>The <span class="site-name"><%= siteName %></span> Team</p>
    </div>
    <div class="footer">
      <p>&copy; <%= new Date().getFullYear() %> <span class="site-name"><%= siteName %></span>. All rights reserved.</p>
      <% if (typeof companyAddress !== 'undefined' && companyAddress) { %>
        <p><%= companyAddress %></p>
      <% } %>
    </div>
  </div>
</body>
</html>
