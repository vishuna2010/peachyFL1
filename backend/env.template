# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/peachyfl_db

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=1d

# AWS S3 Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET_NAME=your-s3-bucket-name

# Email Configuration
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-email-password
EMAIL_FROM_ADDRESS=noreply@yourdomain.com

# Frontend URLs
FRONTEND_URL_BASE=http://localhost:3001
BACKEND_URL_BASE=http://localhost:3000

# Company Information
COMPANY_NAME=Your Company Name
COMPANY_ADDRESS=123 Main St, City, State 12345
COMPANY_LOGO_URL=https://yourdomain.com/logo.png
COMPANY_PHONE=+1-555-123-4567
COMPANY_EMAIL=contact@yourdomain.com
COMPANY_WEBSITE=yourdomain.com

# Payment Gateway Configuration
# Stripe
STRIPE_ENABLED=false
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_TEST_MODE=true

# PayPal
PAYPAL_ENABLED=false
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret
PAYPAL_SANDBOX=true

# PlugNPay
PLUGNPAY_ENABLED=false
PLUGNPAY_MERCHANT_ID=your_plugnpay_merchant_id
PLUGNPAY_USERNAME=your_plugnpay_username
PLUGNPAY_PASSWORD=your_plugnpay_password
PLUGNPAY_GATEWAY_URL=https://pay1.plugnpay.com/pay
PLUGNPAY_TEST_MODE=true
PLUGNPAY_ACH_ENABLED=false
PLUGNPAY_AUTO_SETTLE=true

# Cash on Delivery
COD_ENABLED=true
COD_INSTRUCTIONS=Please have exact change ready for delivery.
COD_REQUIRE_CHANGE=true

# Bank Transfer
BANK_TRANSFER_ENABLED=false
BANK_NAME=Your Bank Name
BANK_ACCOUNT_NUMBER=your_account_number
BANK_ROUTING_NUMBER=your_routing_number
BANK_ACCOUNT_HOLDER=Your Name
BANK_TRANSFER_INSTRUCTIONS=Please include order number in transfer description.

# Mock Gateway (for testing)
MOCK_GATEWAY_ENABLED=true

# General Payment Settings
PAYMENT_CURRENCY=USD
PAYMENT_TIMEOUT_MINUTES=30
AUTO_CAPTURE_PAYMENTS=true
REQUIRE_PAYMENT_CONFIRMATION=false

# Security
DELIVERY_CONFIRMATION_SECRET=your-delivery-confirmation-secret

# Logging
LOG_LEVEL=info 