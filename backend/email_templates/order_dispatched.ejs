<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Your <%= siteName %> Order #<%= order.id %> Has Shipped!</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      padding: 0;
      background-color: #FFF5F8; /* Light Pastel */
      color: #333333;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }
    .container {
      width: 100%;
      max-width: 600px;
      margin: 20px auto;
      background-color: #FFFFFF;
      border-radius: 8px;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
      overflow: hidden;
    }
    .header {
      background-color: #FC7099; /* Peach Pink */
      color: #FFFFFF;
      padding: 20px;
      text-align: center;
    }
    .header h1 {
      margin: 0;
      font-size: 22px; /* Slightly smaller for notification emails */
    }
    .content {
      padding: 25px 30px;
      line-height: 1.6;
    }
    .content h2 {
      color: #FC7099; /* Peach Pink for headings */
      margin-top: 0;
      font-size: 20px;
    }
    .content h3 {
      color: #333333; /* Standard dark color for sub-sub-headings */
      margin-top: 20px;
      font-size: 18px;
    }
    .content p {
      margin: 0 0 15px 0;
    }
    .tracking-info {
      background-color: #FFF5F8; /* Light Pastel to blend with body, but framed by content area */
      padding: 15px;
      border: 1px solid #F6A03C; /* Orange Gold border for accent */
      border-radius: 5px;
      margin: 20px 0;
    }
    .tracking-info p {
      margin-bottom: 8px;
      font-size: 1em;
    }
    .tracking-info strong {
      color: #333333;
    }
    .button-container {
        text-align: center;
        margin-top: 20px;
        margin-bottom: 15px;
    }
    .button-link { /* For <a> tags styled as buttons */
      display: inline-block;
      background-color: #FC7099; /* Peach Pink */
      color: #FFFFFF !important;
      padding: 12px 25px;
      text-decoration: none;
      border-radius: 5px;
      font-weight: bold;
      font-size: 16px;
    }
    .item-list {
      margin-top: 10px; /* Reduced margin */
      padding-left: 0;
      list-style-type: none;
    }
    .item-list li {
      border-bottom: 1px solid #eeeeee;
      padding: 10px 0;
      font-size: 0.95em;
    }
    .item-list li:last-child {
      border-bottom: none;
    }
    .footer {
      text-align: center;
      padding: 20px;
      font-size: 0.85em;
      color: #777777;
      background-color: #FFF5F8; /* Light Pastel */
    }
    .footer p {
      margin: 5px 0;
    }
    a {
      color: #FC7099; /* Peach Pink for links */
      text-decoration: underline;
    }
    a:hover {
      text-decoration: none;
    }
    .site-name {
        font-weight: bold;
    }
    .shipping-address p {
      margin: 0 0 5px 0; /* Tighter spacing for address lines */
      line-height: 1.4;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>Great News, <%= userName %>!</h1>
    </div>
    <div class="content">
      <h2>Your <span class="site-name"><%= siteName %></span> Order #<%= order.id %> Has Shipped!</h2>
      <p>We're excited to let you know that your recent order from <span class="site-name"><%= siteName %></span> has been dispatched and is on its way to you.</p>

      <% if (order.shipping_carrier && order.tracking_number) { %>
      <div class="tracking-info">
        <p><strong>Carrier:</strong> <%= order.shipping_carrier %></p>
        <p><strong>Tracking Number:</strong> <%= order.tracking_number %></p>
        <% if (order.tracking_link) { %>
          <div class="button-container">
            <a href="<%= order.tracking_link %>" class="button-link">Track Your Shipment</a>
          </div>
        <% } %>
      </div>
      <% } %>

      <% if (order.estimated_delivery_date) { %>
        <p><strong>Estimated Delivery:</strong> <span class="accent-text"><%= new Date(order.estimated_delivery_date).toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></span></p>
      <% } %>

      <h3>Shipping To:</h3>
      <div class="shipping-address">
        <p>
          <%= userName %><br>
          <%= order.shipping_address_line1 %><br>
          <% if (order.shipping_address_line2) { %><%= order.shipping_address_line2 %><br><% } %>
          <%= order.shipping_city %>, <%= order.shipping_state_province_region ? order.shipping_state_province_region + ' ' : '' %><%= order.shipping_postal_code %><br>
          <%= order.shipping_country %>
        </p>
      </div>

      <% if (order.items && order.items.length > 0) { %>
        <h3>Items in this Shipment:</h3>
        <ul class="item-list">
          <% order.items.forEach(function(item) { %>
            <li>
              <%= item.product_name_at_purchase || item.name %>
              <% if (item.product_sku_at_purchase) { %>(SKU: <%= item.product_sku_at_purchase %>)<% } %>
              - Qty: <%= item.quantity %>
            </li>
          <% }); %>
        </ul>
      <% } %>

      <p>If you have any questions about your order, please don't hesitate to <a href="mailto:<%= supportEmail %>">contact us</a> or reply to this email.</p>
      <p>Thank you for shopping with <span class="site-name"><%= siteName %></span>!</p>
    </div>
    <div class="footer">
      <p>&copy; <%= new Date().getFullYear() %> <span class="site-name"><%= siteName %></span>. All rights reserved.</p>
      <% if (typeof companyAddress !== 'undefined' && companyAddress) { %>
        <p><%= companyAddress %></p>
      <% } %>
    </div>
  </div>
</body>
</html>
