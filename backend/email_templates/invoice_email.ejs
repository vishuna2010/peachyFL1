<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Your Invoice from <%= siteName %></title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      padding: 0;
      background-color: #FFF5F8; /* Light Pastel */
      color: #333333;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }
    .container {
      width: 100%;
      max-width: 600px;
      margin: 20px auto;
      background-color: #FFFFFF;
      border-radius: 8px;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
      overflow: hidden;
    }
    .header {
      background-color: #FC7099; /* Peach Pink */
      color: #FFFFFF;
      padding: 20px;
      text-align: center;
    }
    .header h1 {
      margin: 0;
      font-size: 22px;
    }
    .content {
      padding: 25px 30px;
      line-height: 1.6;
    }
    .content p {
      margin: 0 0 15px 0;
    }
    .content strong { /* Ensure strong tags are clearly visible */
        color: #333333;
    }
    .footer {
      text-align: center;
      padding: 20px;
      font-size: 0.85em;
      color: #777777;
      background-color: #FFF5F8; /* Light Pastel */
    }
    .footer p {
      margin: 5px 0;
    }
    .site-name {
        font-weight: bold;
    }
    a {
      color: #FC7099; /* Peach Pink for links */
      text-decoration: underline;
    }
    a:hover {
      text-decoration: none;
    }
    .accent-text {
      color: #F6A03C; /* Orange Gold */
    }
    .button-link { /* Style for consistency, though not used as a primary button here */
      display: inline-block;
      background-color: #FC7099; /* Peach Pink */
      color: #FFFFFF !important;
      padding: 10px 15px; /* Slightly smaller for less prominent links if used as button */
      text-decoration: none;
      border-radius: 5px;
      font-weight: bold;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>Your Invoice from <span class="site-name"><%= siteName %></span></h1>
    </div>
    <div class="content">
      <p>Dear <%= userName %>,</p>
      <p>Thank you for your recent order! Please find your invoice (Order #<span class="accent-text"><%= orderId %></span>) attached to this email as a PDF document.</p>

      <% if (typeof orderTotal !== 'undefined' && orderTotal && typeof currencySymbol !== 'undefined' && currencySymbol) { %>
        <p><strong>Order Total:</strong> <span class="accent-text"><%= currencySymbol %><%= orderTotal %></span></p>
      <% } %>

      <% if (typeof viewOrderLink !== 'undefined' && viewOrderLink) { %>
        <p>You can also view your order details online by visiting: <a href="<%= viewOrderLink %>">View Your Order</a></p>
      <% } %>

      <p>If you have any questions regarding your invoice or order, please feel free to <a href="mailto:<%= supportEmail %>">contact our support team</a>.</p>
      <p>We appreciate your business!</p>
      <p>Sincerely,<br>The <span class="site-name"><%= siteName %></span> Team</p>
    </div>
    <div class="footer">
      <p>&copy; <%= new Date().getFullYear() %> <span class="site-name"><%= siteName %></span>. All rights reserved.</p>
      <% if (typeof companyAddress !== 'undefined' && companyAddress) { %>
        <p><%= companyAddress %></p>
      <% } %>
    </div>
  </div>
</body>
</html>
