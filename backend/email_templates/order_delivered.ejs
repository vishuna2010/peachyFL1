<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Your <%= siteName %> Order #<%= order.id %> Has Been Delivered!</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      padding: 0;
      background-color: #FFF5F8; /* Light Pastel */
      color: #333333;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }
    .container {
      width: 100%;
      max-width: 600px;
      margin: 20px auto;
      background-color: #FFFFFF;
      border-radius: 8px;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
      overflow: hidden;
    }
    .header {
      background-color: #5BAA41; /* Fresh Green for delivery confirmation */
      color: #FFFFFF;
      padding: 20px;
      text-align: center;
    }
    .header h1 {
      margin: 0;
      font-size: 22px;
    }
    .content {
      padding: 25px 30px;
      line-height: 1.6;
    }
    .content h2 {
      color: #5BAA41; /* Fresh Green for headings */
      margin-top: 0;
      font-size: 20px;
    }
    .content p {
      margin: 0 0 15px 0;
    }
    .button-container {
      text-align: center;
      margin: 25px 0;
    }
    .button-link { /* Main CTA button */
      display: inline-block;
      background-color: #FC7099; /* Peach Pink for primary actions */
      color: #FFFFFF !important;
      padding: 12px 25px;
      text-decoration: none;
      border-radius: 5px;
      font-weight: bold;
      font-size: 16px;
    }
    .item-list {
      margin-top: 15px;
      padding-left: 0;
      list-style-type: none;
      font-size: 0.95em;
      color: #555555;
    }
    .item-list li {
      padding: 8px 0;
      border-bottom: 1px solid #eeeeee;
    }
    .item-list li:last-child {
      border-bottom: none;
    }
    .secondary-links {
        text-align: center;
        margin-top: 20px;
        font-size: 0.9em;
    }
    .secondary-links a {
        margin: 0 10px;
        color: #FC7099; /* Peach Pink for secondary links too */
    }
    .footer {
      text-align: center;
      padding: 20px;
      font-size: 0.85em;
      color: #777777;
      background-color: #FFF5F8; /* Light Pastel */
    }
    .footer p {
      margin: 5px 0;
    }
    a { /* General link styling */
      color: #FC7099; /* Peach Pink for links */
      text-decoration: underline;
    }
    a:hover {
      text-decoration: none;
    }
    .site-name {
        font-weight: bold;
    }
    .accent-text {
      color: #F6A03C; /* Orange Gold */
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>Order Delivered!</h1>
    </div>
    <div class="content">
      <h2>Hi <%= userName %>,</h2>
      <p>Great news! Your <span class="site-name"><%= siteName %></span> order #<strong><%= order.id %></strong> has been successfully delivered.</p>

      <p>We hope you love your purchase! If you have a moment, we'd greatly appreciate it if you could share your thoughts by reviewing the products you received.</p>
      <div class="button-container">
        <a href="<%= order.reviewLink %>" class="button-link">Review Your Products</a>
      </div>

      <% if (order.items && order.items.length > 0) { %>
        <p><strong>Items in this order:</strong></p>
        <ul class="item-list">
          <% order.items.forEach(function(item) { %>
            <li>
              <%= item.product_name_at_purchase || item.name %>
              <% if (item.product_sku_at_purchase) { %>(SKU: <%= item.product_sku_at_purchase %>)<% } %>
              - Qty: <%= item.quantity %>
            </li>
          <% }); %>
        </ul>
      <% } %>

      <div class="secondary-links">
        <a href="<%= order.viewOrderLink %>">View Order Details</a>
        <% if (typeof supportEmail !== 'undefined' && supportEmail) { %>
          | <a href="mailto:<%= supportEmail %>">Contact Support</a>
        <% } %>
      </div>

      <p style="margin-top: 25px;">Thank you for choosing <span class="site-name"><%= siteName %></span>!</p>
    </div>
    <div class="footer">
      <p>&copy; <%= new Date().getFullYear() %> <span class="site-name"><%= siteName %></span>. All rights reserved.</p>
      <% if (typeof companyAddress !== 'undefined' && companyAddress) { %>
        <p><%= companyAddress %></p>
      <% } %>
    </div>
  </div>
</body>
</html>
